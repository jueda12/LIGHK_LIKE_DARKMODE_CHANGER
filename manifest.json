{
  "manifest_version": 3,
  "name": "LIHKG Like Dark Mode Changer",
  "version": "1.0.0",
  "description": "Use right click to toggle LIHKG-like dark mode colors on webpages.",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
